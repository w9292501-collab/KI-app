# Cytonix configuration template.
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env file — it is in .gitignore.

# Which AI provider to use: "groq" (cloud, fast, free tier) or "ollama" (local)
CYTONIX_PROVIDER=groq

# --- Groq (https://console.groq.com) ---
# Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (only needed if CYTONIX_PROVIDER=ollama) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
